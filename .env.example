# OPENROUTER_API_KEY: Dapatkan key gratis di https://openrouter.ai/keys
# Required for real AI responses. Without it, app runs in simulation mode.
OPENROUTER_API_KEY="sk-or-v1-..."

# OPENROUTER_MODEL: Model yang digunakan (default: openai/gpt-oss-120b:free)
OPENROUTER_MODEL="openai/gpt-oss-120b:free"

# APP_URL: URL tempat app dihosting
APP_URL="https://maxsales.qzz.io"

# VITE_API_URL: URL untuk Cloudflare Worker (opsional, untuk production)
VITE_API_URL=
